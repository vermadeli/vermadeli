  input.className="letter-input";
  input.maxLength=1;
  input.dataset.number=number;
input.addEventListener("focus", ()=>{

  document
    .querySelectorAll(".selected-cell")
    .forEach(el =>
      el.classList.remove("selected-cell")
    );

  selectedInput = input;

  input.classList.add("selected-cell");
});

  input.addEventListener("input",e=>{
    values[number]=e.target.value.toUpperCase();
    sync(number);
  });

  wrapper.appendChild(num);
  wrapper.appendChild(input);

  return wrapper;
}

const grid=document.getElementById("grid");

gridCells.forEach(cell=>{
  if(cell===null || (Array.isArray(cell) && cell[0]===null)){
    const black=document.createElement("div");
    black.className="black";
    if(Array.isArray(cell) && cell[1]){
      black.textContent = cell[1];
    }
    grid.appendChild(black);
  } else {
    grid.appendChild(createGridInput(cell[0],cell[1]));
  }
});


const clues=document.getElementById("clues");

clueData.forEach(clue=>{

  const row=document.createElement("div");
  row.className="clue";

  const label=document.createElement("div");
  label.className="clue-label";
  label.textContent=clue.letter + ". " + clue.text;

  const hintBtn=document.createElement("button");
  hintBtn.className="hint-btn";
  hintBtn.textContent="Pista";
  hintBtn.onclick=()=>showHint(clue.hint);

  const answer=document.createElement("div");
  answer.className="clue-answer";

  clue.cells.forEach((number,index)=>{

    const wrap=document.createElement("div");
    wrap.className="clue-cell";

    const input=document.createElement("input");
    input.maxLength=1;
    input.dataset.number=number;

    input.addEventListener("input",e=>{

      const val=e.target.value.toUpperCase();
      values[number]=val;
      sync(number);

      if(val && index < clue.cells.length-1){
        answer.children[index+1].querySelector("input").focus();
      }

    });

    input.addEventListener("keydown",e=>{
      if(e.key==="Backspace" && !e.target.value && index>0){
        answer.children[index-1].querySelector("input").focus();
      }
    });

    const num=document.createElement("div");
    num.className="clue-number";
    num.textContent=number;

    wrap.appendChild(input);
    wrap.appendChild(num);

    answer.appendChild(wrap);

  });

  row.appendChild(label);
  row.appendChild(hintBtn);
  row.appendChild(answer);

  clues.appendChild(row);

});
</script>

