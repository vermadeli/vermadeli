function sync(number){
  document.querySelectorAll(`[data-number="${number}"]`)
    .forEach(el => el.value = values[number] || "");
  checkFinished();
}


let celebrationShown = false;

let selectedInput = null;

function showHint(text){

  document.getElementById("hintText").textContent = text;

  document.getElementById("hintModal").style.display = "flex";
}

function closeHint(){

  document.getElementById("hintModal").style.display = "none";
}

function paintSelected(style){

  if(!selectedInput) return;

  selectedInput.classList.remove(
    "ink-sepia",
    "ink-blue",
    "ink-italic"
  );

  if(style !== "clear"){
    selectedInput.classList.add("ink-" + style);
  }
}


function checkFinished(){

  const solved = Object.keys(solution).every(number =>
    (values[number] || "") === solution[number]
  );

  if(solved && !celebrationShown){

    celebrationShown = true;

    const overlay =
      document.getElementById("celebrationOverlay");

    overlay.style.display = "flex";

    launchConfetti();

  }
}

function closeCelebration(){

  document.getElementById(
    "celebrationOverlay"
  ).style.display = "none";

}

function launchConfetti(){

  const colors=[
    "#ff4d6d",
    "#ffbe0b",
    "#8338ec",
    "#3a86ff",
    "#06d6a0",
    "#fb5607"
  ];

  for(let i=0;i<260;i++){

    const piece=document.createElement("div");

    piece.className="confetti";

    piece.style.left=Math.random()*100+"vw";

    piece.style.background=
      colors[Math.floor(Math.random()*colors.length)];

    piece.style.borderRadius=
      Math.random()>.5 ? "50%" : "2px";

    piece.style.animationDuration=
      (3 + Math.random()*2)+"s";

    piece.style.transform=
      `rotate(${Math.random()*360}deg)`;

    document.body.appendChild(piece);

    setTimeout(()=>{
      piece.remove();
    },5500);

  }
}

