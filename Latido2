  width:100%;

  margin-top:2mm;
  margin-right:0;
  margin-bottom:1mm;
  margin-left:0;

  padding:0;
}

.clue-cell{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-end;

  margin:0;
  padding:0;
}

.clue-cell input{
  width:5mm;
  height:3mm;

  border:none;
  border-bottom:1px solid black;
  border-radius:0;

  background:transparent;

  font-size:40pt;
  margin:0;
  padding:0;
}

.clue-number{
  font-size:10pt;
  line-height:1;
  margin-top:0;
  padding:0;
  color:black;
}

}
</style>
